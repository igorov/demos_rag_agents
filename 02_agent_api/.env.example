# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
HISTORY_LIMIT=10

# Qdrant
QDRANT_URL=https://your-cluster-url.qdrant.tech
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=data-academy

# Neon MCP - BD (opcional - dejar en blanco para deshabilitar)
NEON_API_KEY=
NEON_PROJECT_ID=

# Groq (InputGuardrail — Capas 7 y 8: Llama Prompt Guard 2 y Llama Guard 4)
GROQ_API_KEY=gsk_...
GROQ_PROMPT_GUARD_MODEL=meta-llama/Llama-Prompt-Guard-2-86M
GROQ_LLAMA_GUARD_MODEL=openai/gpt-oss-safeguard-20b
GROQ_TIMEOUT_SECONDS=3

# InputGuardrail — Capa 4 (timeout anti-ReDoS por regla, en segundos)
CUSTOM_REGEX_TIMEOUT_SECONDS=1
